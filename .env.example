PORT=8080
# Disable request access logs for benchmarks or high-volume local runs.
# ACCESS_LOGS=false

# Tune async ingestion capacity.
# INGEST_WORKERS=2
# INGEST_QUEUE_SIZE=1024

# Set one or multiple API keys (comma separated). Leave empty to disable auth in dev.
# API_KEYS=dev-key-1,dev-key-2

# Configure PostgreSQL (optional). If empty, an in-memory store is used.
# Example DSN:
# POSTGRES_DSN=host=localhost user=postgres password=postgres dbname=realtime_logs port=5432 sslmode=disable TimeZone=UTC
